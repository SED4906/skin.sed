<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>9000</defaultcontrol>
	<backgroundcolor>background</backgroundcolor>
	<controls>
		<control type="button" id="20000">
			<include>HiddenObject</include>
			<animation effect="fade" time="300" start="100" end="0">Focus</animation>
			<onfocus>SetFocus(2000)</onfocus>
			<onclick>noop</onclick>
			<visible allowhiddenfocus="true">Control.HasFocus(20000)</visible>
		</control>
		<control type="button" id="20001">
			<include>HiddenObject</include>
			<animation effect="fade" time="300" start="100" end="0">Focus</animation>
			<onfocus>SetFocus(2000)</onfocus>
			<onclick>noop</onclick>
			<visible allowhiddenfocus="true">Control.HasFocus(20001)</visible>
		</control>
		<include>DefaultBackground</include>
		<control type="multiimage">
			<depth>DepthBackground</depth>
			<include>FullScreenDimensions</include>
			<aspectratio>scale</aspectratio>
			<fadetime>600</fadetime>
			<animation effect="zoom" center="auto" end="102,102" time="0" condition="Integer.IsGreater(System.StereoscopicMode,0)">conditional</animation>
			<animation effect="fade" start="0" end="100" time="400">WindowOpen</animation>
			<animation effect="fade" start="100" end="0" time="300">WindowClose</animation>
			<animation effect="fade" time="400">VisibleChange</animation>
			<imagepath background="true" colordiffuse="bg_overlay">$VAR[HomeFanartVar]</imagepath>
			<visible>!Player.HasMedia</visible>
		</control>
		<control type="group">
			<control type="image">
				<left>296</left>
				<top>44</top>
				<width>128</width>
				<height>128</height>
				<texture>lists/focus.png</texture>
			</control>
			<control type="image">
				<left>296</left>
				<top>44</top>
				<width>128</width>
				<height>128</height>
				<texture>$INFO[System.ProfileThumb]</texture>
			</control>
			<control type="label">
				<left>440</left>
				<top>44</top>
				<height>128</height>
				<font>font45</font>
				<aligny>center</aligny>
				<label>$INFO[System.ProfileName]</label>
			</control>
		</control>
		<control type="grouplist" id="9000">
			<top>288</top>
			<itemgap>20</itemgap>
			<orientation>horizontal</orientation>
			<usecontrolcoords>true</usecontrolcoords>
			<onup>700</onup>
			<control type="button" id="901">
				<height>214</height>
				<width>230</width>
				<label>Weather</label>
				<align>center</align>
				<aligny>top</aligny>
				<font>font37</font>
				<textoffsety>160</textoffsety>
				<texturefocus colordiffuse="F0F0F0F0">icons/lefthomeweather.png</texturefocus>
				<texturenofocus colordiffuse="80808080">icons/lefthomeweather.png</texturenofocus>
				<onclick>ActivateWindow(Weather)</onclick>
			</control>
			<control type="button" id="902">
				<height>214</height>
				<width>460</width>
				<label>Music</label>
				<align>center</align>
				<aligny>top</aligny>
				<font>font37</font>
				<textoffsety>160</textoffsety>
				<texturefocus colordiffuse="F0F0F0F0">icons/middlehomebox1.png</texturefocus>
				<texturenofocus colordiffuse="80808080">icons/middlehomebox1.png</texturenofocus>
				<onclick>ActivateWindow(Music)</onclick>
			</control>
			<control type="button" id="903">
				<height>214</height>
				<width>460</width>
				<label>Videos</label>
				<align>center</align>
				<aligny>top</aligny>
				<font>font37</font>
				<textoffsety>160</textoffsety>
				<texturefocus colordiffuse="F0F0F0F0">icons/middlehomebox2.png</texturefocus>
				<texturenofocus colordiffuse="80808080">icons/middlehomebox2.png</texturenofocus>
				<onclick>ActivateWindow(Videos)</onclick>
			</control>
			<control type="button" id="904">
				<height>214</height>
				<width>460</width>
				<label>YouTube</label>
				<align>center</align>
				<aligny>top</aligny>
				<font>font37</font>
				<textoffsety>160</textoffsety>
				<texturefocus colordiffuse="F0F0F0F0">icons/middlehomebox3.png</texturefocus>
				<texturenofocus colordiffuse="80808080">icons/middlehomebox3.png</texturenofocus>
				<onclick>RunAddon(plugin.video.youtube)</onclick>
			</control>
			<control type="button" id="905">
				<height>214</height>
				<width>230</width>
				<label>Add-ons</label>
				<align>center</align>
				<aligny>top</aligny>
				<font>font37</font>
				<textoffsety>160</textoffsety>
				<texturefocus colordiffuse="F0F0F0F0">icons/righthomeaddons.png</texturefocus>
				<texturenofocus colordiffuse="80808080">icons/righthomeaddons.png</texturenofocus>
				<onclick>ActivateWindow(1100)</onclick>
			</control>
		</control>
		<control type="grouplist" id="700">
			<orientation>horizontal</orientation>
			<itemgap>16</itemgap>
			<right>296</right>
			<height>64</height>
			<width>512</width>
			<top>76</top>
			<ondown>9000</ondown>
			<align>right</align>	 
			<control type="button" id="74">
				<width>64</width>
				<height>64</height>
				<align>center</align>
				<aligny>center</aligny>
				<texturefocus colordiffuse="A0A0A0A0">icons/fullscreen2.png</texturefocus>
				<texturenofocus colordiffuse="80808080">icons/fullscreen2.png</texturenofocus>
				<onclick>Fullscreen</onclick>
				<visible>Player.HasMedia()</visible>
			</control>
			<control type="button" id="73">
				<width>64</width>
				<height>64</height>
				<align>center</align>
				<aligny>center</aligny>
				<texturefocus colordiffuse="A0A0A0A0">icons/search2.png</texturefocus>
				<texturenofocus colordiffuse="80808080">icons/search2.png</texturenofocus>
				<onclick>ActivateWindow(1107)</onclick>
			</control>
			<control type="button" id="72">
				<width>64</width>
				<height>64</height>
				<align>center</align>
				<aligny>center</aligny>
				<texturefocus colordiffuse="A0A0A0A0">icons/settings2.png</texturefocus>
				<texturenofocus colordiffuse="80808080">icons/settings2.png</texturenofocus>
				<onclick>ActivateWindow(settings)</onclick>
			</control>
			<control type="button" id="71">
				<width>64</width>
				<height>64</height>
				<align>center</align>
				<aligny>center</aligny>
				<texturefocus colordiffuse="A0A0A0A0">icons/power2.png</texturefocus>
				<texturenofocus colordiffuse="80808080">icons/power2.png</texturenofocus>
				<onclick>ActivateWindow(shutdownmenu)</onclick>
			</control>
		</control>
		<control type="group">
			<bottom>0</bottom>
			<height>70</height>
			<animation effect="fade" start="0" end="100" time="300" delay="300">WindowOpen</animation>
			<animation effect="fade" start="100" end="0" time="200">WindowClose</animation>
			<include condition="!Skin.HasSetting(hide_mediaflags)" content="MediaFlags">
				<param name="infolabel_prefix" value="Container." />
				<param name="resolution_var" value="$VAR[ContainerResolutionFlagVar]" />
			</include>
			<control type="rss">
				<animation effect="slide" end="0,90" time="300" tween="sine" easing="inout" condition="$EXP[infodialog_active]">conditional</animation>
				<left>0</left>
				<bottom>0</bottom>
				<height>39</height>
				<width>100%</width>
				<font>font12</font>
				<urlset>1</urlset>
				<hitrect x="-100" y="0" w="1" h="1" />
				<titlecolor>button_focus</titlecolor>
				<textcolor>button_focus</textcolor>
				<shadowcolor>text_shadow</shadowcolor>
				<headlinecolor>FFC0C0C0</headlinecolor>
				<visible>Skin.HasSetting(hide_mediaflags) | !ControlGroup(2000).HasFocus</visible>
				<animation effect="fade" time="300">VisibleChange</animation>
			</control>
		</control>
		<control type="label">
			<top>76</top>
			<right>288</right>
			<label>$INFO[System.Time]</label>
			<width>0</width>
			<height>64</height>
			<font>font45</font>
			<aligny>center</aligny>
		</control>
	</controls>
</window>
